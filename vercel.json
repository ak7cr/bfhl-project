{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "api/bfhl.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/bfhl.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
